% ---- quadratic form: qf{x}{M} = x^T M x ; qf{x}{} = x^T x ----
\providecommand{\qf}[2]{%
  \if\relax\detokenize{#2}\relax
    #1^{\top}#1%
  \else
    #1^{\top}#2#1%
  \fi
}

% ---- normalized adjacency / laplacian symbols ----
\providecommand{\NA}{\widetilde{A}}
\providecommand{\NL}{\widetilde{L}}

% --- fact environment: compatible with \begin{fact}[optional title]\label{...} ---
\makeatletter
% if fact already defined, undefine it first
\@ifundefined{fact}{}{%
  \let\fact\relax
  \let\endfact\relax
}

% Prefer sharing theorems' numbering if possible:
% 1) if counter theorem exists -> share with theorem
% 2) else if counter tcb@cnt@theorem exists -> share with that (ElegantBook/tcolorbox)
% 3) else -> own counter by chapter
\@ifundefined{c@theorem}{%
  \@ifundefined{c@tcb@cnt@theorem}{%
    \newtheorem{fact}{事实}[chapter]%
  }{%
    \newtheorem{fact}[tcb@cnt@theorem]{事实}%
  }%
}{%
  \newtheorem{fact}[theorem]{事实}%
}
\makeatother

