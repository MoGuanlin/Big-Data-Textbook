%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% Merged additions from `additional_sty.sty` and `hidden_gem.sty`
% Merged on: 2026-02-17
% Notes:
% 1) 为避免破坏主教材已有命令，这里对“同名但含义不同”的命令只做可选切换，
%    不在加载时强制覆盖（典型冲突：\la, \m, \P, \I, \Pr, \E, \Var, \Cov 等）。
% 2) hyperref/cleveref 的加载顺序较敏感：本文件会在未加载时补齐；若主文档已有设置，以主文档为准。
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

\makeatletter
% ---------- packages (safe require) ----------
\@ifpackageloaded{xcolor}{}{\RequirePackage{xcolor}}
\@ifpackageloaded{ctex}{}{\RequirePackage{ctex}}
\@ifpackageloaded{graphicx}{}{\RequirePackage{graphicx}}
\@ifpackageloaded{amsmath}{}{\RequirePackage{amsmath}}
\@ifpackageloaded{amssymb}{}{\RequirePackage{amssymb}}
\@ifpackageloaded{amsfonts}{}{\RequirePackage{amsfonts}}
\@ifpackageloaded{amsthm}{}{\RequirePackage{amsthm}}
\@ifpackageloaded{fancyhdr}{}{\RequirePackage{fancyhdr}}
\@ifpackageloaded{boxedminipage}{}{\RequirePackage{boxedminipage}}
\@ifpackageloaded{caption}{}{\RequirePackage{caption}}
\@ifpackageloaded{subcaption}{}{\RequirePackage{subcaption}}
\@ifpackageloaded{grffile}{}{\RequirePackage{grffile}}
\@ifpackageloaded{booktabs}{}{\RequirePackage{booktabs}}
\@ifpackageloaded{textcomp}{}{\RequirePackage{textcomp}}
\@ifpackageloaded{colortbl}{}{\RequirePackage{colortbl}}
\@ifpackageloaded{tikz}{}{\RequirePackage{tikz}}
\@ifpackageloaded{inconsolata}{}{\RequirePackage{inconsolata}}
\@ifpackageloaded{algorithm2e}{}{\RequirePackage[oldcommands,ruled,vlined,linesnumbered]{algorithm2e}}
\@ifpackageloaded{enumitem}{}{\RequirePackage{enumitem}\setitemize{nolistsep}}
\@ifpackageloaded{tcolorbox}{}{\RequirePackage[most]{tcolorbox}}
\@ifpackageloaded{pgfornament}{}{\RequirePackage{pgfornament}}
\@ifpackageloaded{nicefrac}{}{\RequirePackage{nicefrac}}

% hyperref & cleveref (load late)
\@ifpackageloaded{hyperref}{}{\RequirePackage{hyperref}}
\@ifpackageloaded{cleveref}{}{\RequirePackage[noabbrev,capitalise,nameinlink]{cleveref}}
\makeatother

% TikZ libraries used in added chapters
\usetikzlibrary{matrix,shapes,arrows,positioning,chains,patterns,trees,decorations.pathmorphing}

% Allow page breaks in long equations
\allowdisplaybreaks

% ---------- color fallbacks (if not already defined) ----------
\makeatletter
\@ifundefined{color@ADBlue}{\definecolor{ADBlue}{RGB}{1,120,217}}{}
\@ifundefined{color@ADGrey}{\definecolor{ADGrey}{gray}{0.45}}{}
\@ifundefined{color@ADLightGrey}{\definecolor{ADLightGrey}{gray}{0.93}}{}
\makeatother

% beamer compatibility (some added macros used \structure)
\providecommand{\structure}[1]{#1}

% ---------- helpers from additional_sty.sty ----------
\providecommand{\citestr}[1]{{\fontsize{8}{9}\selectfont \structure{[#1]}}}
\providecommand{\smallcitestr}[1]{\small{\structure{[#1]}}}
\providecommand{\ip}[1]{\langle#1\rangle}
\providecommand{\myref}[1]{\textcolor{blue}{#1}}
\providecommand{\myemph}[1]{\textcolor{blue}{#1}}

% box for pseudo code (uses ADLightGrey)
\newsavebox{\codebox}
\newenvironment{code}
{\fboxsep6pt\begin{lrbox}{\codebox}%
\begin{minipage}{\dimexpr\columnwidth-2\fboxsep\relax}\ttfamily}
{\end{minipage}\end{lrbox}%
\begin{center}\colorbox{ADLightGrey}{\usebox{\codebox}}\end{center}}

% Replacement for notes with small arrows 
\newcommand{\bigoh}{\mathcal{O}}
\newcommand{\noteA}[1]{{\fboxsep1pt\colorbox{yellow!20!white}{#1}}}
\newcommand{\noteB}[1]{{\fboxsep1pt\colorbox{green!20!white}{#1}}}
\newcommand{\noteC}[1]{{\fboxsep1pt\colorbox{red!20!white}{#1}}}
\newcommand{\boxA}{\fboxsep0pt\colorbox{yellow!20!white}{$\Box$}\xspace}
\newcommand{\boxB}{\fboxsep0pt\colorbox{green!20!white}{$\Box$}\xspace}
\newcommand{\boxC}{\fboxsep0pt\colorbox{red!20!white}{$\Box$}\xspace}

\newenvironment{notes}{\begin{quote}\small}{\end{quote}}

% Some convenience macros (require xcolor)
\newcommand{\hl}[1]{\textcolor{ADBlue}{#1}}
\newcommand{\lit}[1]{\textcolor{ADGrey}{[#1]}}

\newcommand{\SECTION}[1]{%
  \begin{center}
    \Large\hl{#1}    
  \end{center}}

\newcommand{\problem}{\textbf{问题:}}
\newcommand{\idea}{\textbf{思路:}}
\newcommand{\supplement}{\textbf{补充:}}

% algorithm2e
\renewcommand{\algorithmcfname}{算法}

% probability / convenience
\newcommand{\whp}{w.h.p.}
\newcommand{\wpgeq}[1]{w.p.$\geq #1$}
\newcommand{\wpleq}[1]{w.p.$\leq #1$}
\newcommand{\var}{\mathrm{Var}}

\newcommand{\sumn}[1]{\sum_{#1=1}^{n}}
\newcommand{\sumx}[2]{\sum_{#1=1}^{#2}}
\newcommand{\prodn}[1]{\prod_{#1=1}^{n}}
\newcommand{\prodx}[2]{\prod_{#1=1}^{#2}}
\newcommand{\intx}[2]{\int_{#1}^{#2}}
\newcommand{\varset}[1]{#1_1,\dots,#1_n}
\newcommand{\ton}{1,\dots,n}
\newcommand{\tox}[1]{1,\dots,#1}
\newcommand{\fvarset}[2]{#1(#2_1),\dots,#1(#2_n)}
\newcommand{\rspace}[1]{\mathbb{R}^{#1}}
\newcommand{\vecspace}[2]{\mathbb{#1}^{#2}}
\newcommand{\set}[1]{\lbrace {#1}\rbrace}

\newcommand{\bool}{\{0,1\}}
\newcommand{\Ham}{\mathrm{Ham}}
\newcommand{\err}{\mathrm{err}}

% cleveref Chinese labels (only take effect when cleveref is available)
\crefname{table}{表}{表}
\crefname{algorithm}{算法}{算法}
\Crefname{figure}{图}{图}
\crefname{claim}{断言}{断言}
\crefname{lemma}{引理}{引理}
\crefname{corollary}{推论}{推论}
\Crefname{theorem}{定理}{定理}
\Crefname{proof}{证明}{证明}
\Crefname{equation}{等式}{等式}

% caption Chinese table name
\captionsetup[table]{name=表}

% ---------- optional: keep added-chapter macro conventions (conflict-resolving switch) ----------
% In some added chapters, \la was used for \leftarrow and \m for a “minus sign”.
% 你可以在局部（推荐用分组 {} 包起来）调用以下命令以兼容旧写法：
\makeatletter
\let\symbol@orig@la\la
\let\symbol@orig@m\m
\let\symbol@orig@P\P
\makeatother
\newcommand{\UseAddedChapterSymbols}{%
  \renewcommand{\la}{\leftarrow}%
  \renewcommand{\m}{\mathnormal{-}}%
  \renewcommand{\P}{$\mathbf{P}$}%
}
\newcommand{\RestoreMainSymbols}{%
  \makeatletter
  \let\la\symbol@orig@la
  \let\m\symbol@orig@m
  \let\P\symbol@orig@P
  \makeatother
}

% ---------- merged from hidden_gem.sty (safe subset) ----------
% iroshizuku color names
\makeatletter
\@ifundefined{color@ama-iro}{\definecolor{ama-iro}{RGB}{0, 158, 243}}{}
\@ifundefined{color@fuyu-gaki}{\definecolor{fuyu-gaki}{RGB}{251, 74, 52}}{}
\@ifundefined{color@momiji}{\definecolor{momiji}{RGB}{245, 70, 111}}{}
\@ifundefined{color@hotaru-bi}{\definecolor{hotaru-bi}{RGB}{229,221,58}}{}
\@ifundefined{color@kon-peki}{\definecolor{kon-peki}{RGB}{1,120,217}}{}
\@ifundefined{color@shin-kai}{\definecolor{shin-kai}{RGB}{77,98,152}}{}
\@ifundefined{color@shin-ryoku}{\definecolor{shin-ryoku}{RGB}{1,145,97}}{}
\@ifundefined{color@yama-budo}{\definecolor{yama-budo}{RGB}{171,14,122}}{}
\@ifundefined{color@theoremcolor}{\definecolor{theoremcolor}{RGB}{77,98,152}}{}
\@ifundefined{color@definitioncolor}{\definecolor{definitioncolor}{RGB}{255, 213, 179}}{}
\@ifundefined{color@examplecolor}{\definecolor{examplecolor}{RGB}{255, 213, 179}}{}
\makeatother

\newcommand{\nathan}[1]{{\color{ama-iro} \textbf{NH:} #1}}

% Header info (does not affect layout unless you call \setpagestyle)
\newcommand{\varlecturenumber}{}
\newcommand{\varlecturetitle}{}
\newcommand{\varlecturedate}{}
\newcommand{\varlecturername}{}
\newcommand{\varscribename}{}

\newcommand{\lecturenumber}[1]{\renewcommand{\varlecturenumber}{#1}}
\newcommand{\lecturetitle}[1]{\renewcommand{\varlecturetitle}{#1}}
\newcommand{\lecturedate}[1]{\renewcommand{\varlecturedate}{#1}}
\newcommand{\lecturername}[1]{\renewcommand{\varlecturername}{#1}}
\newcommand{\scribename}[1]{\renewcommand{\varscribename}{#1}}

% Page styles (need fancyhdr)
\fancypagestyle{firstpage}{
    \fancyhf{}
    \fancyfoot[C]{\thepage}
    \renewcommand{\headrulewidth}{0pt}
}
\fancypagestyle{mystyle}{
    \fancyhf{}
    \fancyhead[C]{\color{black!50!white}%
      $\diamond$ \textsc{大数据算法\varlecturenumber\;}%
      $\diamond$}
    \fancyfoot[C]{\thepage}
    \renewcommand{\headrulewidth}{0pt}
}
\newcommand{\setpagestyle}{
    \thispagestyle{firstpage}
    \pagestyle{mystyle}
}

% Theorem boxes (define only if not already present)
\makeatletter
\@ifundefined{theorem}{\newtheorem{theorem}{定理}}{}
\@ifundefined{boxtheorem}{\newenvironment{boxtheorem}{\begin{theorem}}{\end{theorem}}}{}
\makeatother
\tcolorboxenvironment{boxtheorem}{colback=shin-kai!20!white, colframe=white,
    colbacktitle=shin-kai!20!white, coltitle=shin-kai}

\makeatletter
\@ifundefined{lemma}{\newtheorem{lemma}[theorem]{引理}}{}
\@ifundefined{boxlemma}{\newenvironment{boxlemma}{\begin{lemma}}{\end{lemma}}}{}
\makeatother
\tcolorboxenvironment{boxlemma}{colback=shin-kai!20!white, colframe=white,
    colbacktitle=shin-kai!20!white, coltitle=shin-kai}

\makeatletter
\@ifundefined{proposition}{\newtheorem{proposition}[theorem]{性质}}{}
\@ifundefined{boxproposition}{\newenvironment{boxproposition}{\begin{proposition}}{\end{proposition}}}{}
\makeatother
\tcolorboxenvironment{boxproposition}{colback=shin-kai!10!white, colframe=white,
    colbacktitle=shin-kai!20!white, coltitle=shin-kai}

\makeatletter
\@ifundefined{observation}{\newtheorem{observation}[theorem]{观察}}{}
\@ifundefined{boxobservation}{\newenvironment{boxobservation}{\begin{observation}}{\end{observation}}}{}
\makeatother
\tcolorboxenvironment{boxobservation}{colback=shin-kai!10!white, colframe=white,
    colbacktitle=shin-kai!20!white, coltitle=shin-kai}

\makeatletter
\@ifundefined{corollary}{\newtheorem{corollary}[theorem]{推论}}{}
\@ifundefined{fact}{\newtheorem{fact}[theorem]{事实}}{}
\@ifundefined{question}{\newtheorem{question}[theorem]{问题}}{}
\@ifundefined{question*}{\newtheorem{question*}{Question}}{}
\@ifundefined{boxquestion}{\newenvironment{boxquestion}{\begin{question}}{\end{question}}}{}
\@ifundefined{boxquestion*}{\newenvironment{boxquestion*}{\begin{question*}}{\end{question*}}}{}
\makeatother
\tcolorboxenvironment{boxquestion}{colback=shin-kai!20!white, colframe=white,
    colbacktitle=shin-kai!20!white, coltitle=shin-kai}
\tcolorboxenvironment{boxquestion*}{colback=shin-kai!20!white, colframe=white,
    colbacktitle=shin-kai!20!white, coltitle=shin-kai}

\makeatletter
\@ifundefined{conjecture}{\newtheorem{conjecture}[theorem]{猜想}}{}
\makeatother

\theoremstyle{definition}
\makeatletter
\@ifundefined{definition}{\newtheorem{definition}[theorem]{定义}}{}
\@ifundefined{boxdefinition}{\newenvironment{boxdefinition}{\begin{definition}}{\end{definition}}}{}
\makeatother
\tcolorboxenvironment{boxdefinition}{colback=definitioncolor, colframe=white,
    colbacktitle=fuyu-gaki!20!white, coltitle=fuyu-gaki}

\makeatletter
\@ifundefined{remark}{\newtheorem{remark}[theorem]{标注}}{}
\@ifundefined{notice}{\newtheorem{notice}[theorem]{注意}}{}
\@ifundefined{claim}{\newtheorem{claim}[theorem]{断言}}{}
\makeatother

\makeatletter
\@ifundefined{example}{\newtheorem{example}[theorem]{例子}}{}
\@ifundefined{boxexample}{\newenvironment{boxexample}{\begin{example}}{\end{example}}}{}
\makeatother
\tcolorboxenvironment{boxexample}{colback=examplecolor!50!white, colframe=white,
    colbacktitle=hotaru-bi!20!white, coltitle=hotaru-bi}

\theoremstyle{definition}
\makeatletter
\@ifundefined{exercise}{\newtheorem{exercise}[theorem]{练习}}{}
\@ifundefined{boxexercise}{\newenvironment{boxexercise}{\begin{exercise}}{\end{exercise}}}{}
\makeatother
\tcolorboxenvironment{boxexercise}{colback=shin-kai!10!white, colframe=white,
    colbacktitle=shin-kai!20!white, coltitle=shin-kai}

% hyperref colors (default; you can override in main tex)
\makeatletter
\AtBeginDocument{%
  \@ifpackageloaded{hyperref}{%
    \hypersetup{
      colorlinks=true,
      linkcolor=momiji,
      filecolor=ama-iro,
      urlcolor=momiji,
      citecolor=shin-ryoku
    }%
  }{}%
}

% QED symbol (safe override)
\AtBeginDocument{%
  \@ifundefined{qedsymbol}{}{%
    \renewcommand{\qedsymbol}{$\blacksquare$}%
  }%
}
\makeatother

% math symbols (new names; avoid overriding existing \Pr/\E/\Var/\Cov/\poly/\eps)
\newcommand{\std}{\operatorname{{std}}}
\newcommand{\tvdist}{\mathrm{dist}_{\mathsf{TV}}}
\newcommand{\dist}{\mathrm{dist}}

% Calligraphic Letters (short names)
\newcommand{\cA}{\mathcal A}\newcommand{\cB}{\mathcal B}\newcommand{\cC}{\mathcal C}
\newcommand{\cD}{\mathcal D}\newcommand{\cE}{\mathcal E}\newcommand{\cF}{\mathcal F}
\newcommand{\cG}{\mathcal G}\newcommand{\cH}{\mathcal H}\newcommand{\cI}{\mathcal I}
\newcommand{\cJ}{\mathcal J}\newcommand{\cK}{\mathcal K}\newcommand{\cL}{\mathcal L}
\newcommand{\cM}{\mathcal M}\newcommand{\cN}{\mathcal N}\newcommand{\cO}{\mathcal O}
\newcommand{\cP}{\mathcal P}\newcommand{\cQ}{\mathcal Q}\newcommand{\cR}{\mathcal R}
\newcommand{\cS}{\mathcal S}\newcommand{\cT}{\mathcal T}\newcommand{\cU}{\mathcal U}
\newcommand{\cV}{\mathcal V}\newcommand{\cW}{\mathcal W}\newcommand{\cX}{\mathcal X}
\newcommand{\cY}{\mathcal Y}\newcommand{\cZ}{\mathcal Z}

% Blackboard Bold letters (dsfont)
\newcommand{\bC}{\mathds C}
\newcommand{\bE}{\mathds E}
\newcommand{\bF}{\mathds F}
\newcommand{\bN}{\mathds N}
\newcommand{\bR}{\mathds R}
\newcommand{\bQ}{\mathds Q}
\newcommand{\bZ}{\mathds Z}

% indicator (dsfont)
\newcommand{\ind}[1]{\mathds{1}\left[ #1 \right]} 

% common sets
\newcommand{\zo}{\{0,1\}}
\newcommand{\pmset}{\{\pm 1\}}

% definitions symbol
\newcommand*{\define}{\mathrel{\vcenter{\baselineskip0.5ex \lineskiplimit0pt
                      \hbox{\scriptsize.}\hbox{\scriptsize.}}}%
                      =}

% e.g. and i.e.
\newcommand*\ie{i.\kern.1em e.\ }
\newcommand*\eg{e.\kern.1em g.\ }

% probability with under-set (new names)
\newcommand{\Pru}[1]{\underset{#1}{\Pr}}
\newcommand{\Exu}[1]{\underset{#1}{\bE}}
