% --------------------------------------------------------------------------------
% THEOREMS
% --------------------------------------------------------------------------------

\newtheorem{theorem}{定理}
\newenvironment{boxtheorem}{\begin{theorem}}{\end{theorem}}
\tcolorboxenvironment{boxtheorem}{colback=shin-kai!20!white, colframe=white,
    colbacktitle=shin-kai!20!white, coltitle=shin-kai}

\newtheorem{lemma}[theorem]{引理}
\newenvironment{boxlemma}{\begin{lemma}}{\end{lemma}}
\tcolorboxenvironment{boxlemma}{colback=shin-kai!20!white, colframe=white,
    colbacktitle=shin-kai!20!white, coltitle=shin-kai}

\newtheorem{proposition}[theorem]{性质}
\newenvironment{boxproposition}{\begin{proposition}}{\end{proposition}}
\tcolorboxenvironment{boxproposition}{colback=shin-kai!10!white, colframe=white,
    colbacktitle=shin-kai!20!white, coltitle=shin-kai}

\newtheorem{observation}[theorem]{观察}
\newenvironment{boxobservation}{\begin{observation}}{\end{observation}}
\tcolorboxenvironment{boxobservation}{colback=shin-kai!10!white, colframe=white,
    colbacktitle=shin-kai!20!white, coltitle=shin-kai}

\newtheorem{corollary}[theorem]{推论}
\newtheorem{fact}[theorem]{事实}

\newtheorem{question}[theorem]{问题}
\newtheorem{question*}{Question}
\newenvironment{boxquestion}{\begin{question}}{\end{question}}
\tcolorboxenvironment{boxquestion}{colback=shin-kai!20!white, colframe=white,
    colbacktitle=shin-kai!20!white, coltitle=shin-kai}
\newenvironment{boxquestion*}{\begin{question*}}{\end{question*}}
\tcolorboxenvironment{boxquestion*}{colback=shin-kai!20!white, colframe=white,
    colbacktitle=shin-kai!20!white, coltitle=shin-kai}

\newtheorem{conjecture}[theorem]{猜想}

\theoremstyle{definition}
\newtheorem{definition}[theorem]{定义}
\newenvironment{boxdefinition}{\begin{definition}}{\end{definition}}
\tcolorboxenvironment{boxdefinition}{colback=definitioncolor, colframe=white,
    colbacktitle=fuyu-gaki!20!white, coltitle=fuyu-gaki}

\newtheorem{remark}[theorem]{标注}

\newtheorem{notice}[theorem]{注意}

\newtheorem{claim}[theorem]{断言}

\newtheorem{example}[theorem]{例子}
\newenvironment{boxexample}{\begin{example}}{\end{example}}
\tcolorboxenvironment{boxexample}{colback=examplecolor!50!white, colframe=white,
    colbacktitle=hotaru-bi!20!white, coltitle=hotaru-bi}

\theoremstyle{definition}
\newtheorem{exercise}[theorem]{练习}
\newenvironment{boxexercise}{\begin{exercise}}{\end{exercise}}
\tcolorboxenvironment{boxexercise}{colback=shin-kai!10!white, colframe=white,
    colbacktitle=shin-kai!20!white, coltitle=shin-kai}

